@page "/Utils"
<h3>Utils</h3>

<div class="card mt-3">
    <div class="card-header pt-1 pb-1 navbar-button">
        <div class="d-flex flex-row justify-content-between align-items-center">
            <div>
                <h4 class="card-title mb-0">Copia todos los datos desde un trámite a la estructura empresas</h4>
            </div>
        
        </div>
    </div>
    <div class="card-body">
        <div class="mb-1 row">
            <div class="alert alert-warning">Este es el mismo procedimiento que se utiliza cada vez que se aprueba un trámite</div>
            <label class="col-sm-2 col-form-label">Id Trámite:</label>
    
                <div class="col-sm-10 d-flex">
                <NumericBox TValue="int?"
                            MaxIntegers="10" 
                            class="rz-textbox form-control"
                            Style="width:100px" 
                            @bind-Value=@IdTramite 
                            />


                @if (!isBusyCopiar)
                {
                    <button type="button" class="btn btn-secondary ms-1" style="width:120px" @onclick=@CopiarClick>Copiar Datos</button>
                }
                else
                {
                    <div class="d-flex flex-row justify-content-end">
                        <Spinner1 Text="Copiando..." />
                    </div>

                }
                
            </div>
        </div>
    </div>
</div>