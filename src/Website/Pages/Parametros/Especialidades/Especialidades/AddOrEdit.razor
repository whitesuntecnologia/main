@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize(Roles = "EspecialidadesEditar")]
<hr class="mt-1 mb-0" />

<EditForm Model="@Model" OnSubmit="OnClickAceptar">
    <Blazored.FluentValidation.FluentValidationValidator />

    <RadzenLayout Style="height: auto">
        <RadzenBody class="mbottom30">
            <div class="mb-1 row">
                <label class="col-sm-3 col-form-label text-end">Descripción:</label>
                <div class="col-sm-9">
                    <RadzenTextBox class="form-control w-100"
                                   MaxLength="200"
                                   @bind-Value=@Model.NombreEspecialidad />
                    <ValidationMessage For="() => Model.NombreEspecialidad" />
                </div>
            </div>

            <div class="mb-1 row">
                <label class="col-sm-3 col-form-label text-end">Rama:</label>
                <div class="col-sm-9">
                    <CustomRadzenDropDown class="form-control"
                                    AllowFiltering=true
                                    TextProperty="Descripcion"
                                    ValueProperty="Id"
                                    Data="@lstRamas"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    @bind-Value="@Model.Rama" />
                    <ValidationMessage For="() => Model.Rama" />
                </div>
            </div>

            @if (IsBaja)
            {
                <div class="mb-1 row">
                    <label class="col-sm-3 col-form-label text-end">Dado de baja:</label>
                    <div class="col-sm-9">
                        <RadzenCheckBox class="mt-1"
                                    @bind-Value=@Model.Baja />
                        <ValidationMessage For="() => Model.Baja" />
                    </div>
                </div>
            }
        </RadzenBody>
        <RadzenFooter class="mt-3">

            <div class="d-flex flex-row text-end justify-content-end">
                @if (!isBusyAceptar)
                {
                    <button type="submit" class="btn btn-violet" style="width: 120px">Aceptar</button>
                    <button type="button" class="btn btn-light" @onclick="@((args) => dialogService.Close(false))" style="width: 120px">Cancelar</button>
                }
                else
                {
                    <Spinner1 Text="Guardando..." />
                }
            </div>

        </RadzenFooter>

    </RadzenLayout>
</EditForm>



