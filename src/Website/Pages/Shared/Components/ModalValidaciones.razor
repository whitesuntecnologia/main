<hr class="mb-2" style="margin-top: -15px;" />
<div class="d-flex flex-row justify-content-start align-items-center">
    <div>
        <span class="material-icons text-danger fs-64">
            sd_card_alert
        </span>
    </div>
    <div class="ps-3">
        @if(!string.IsNullOrWhiteSpace(Title))
        {
            <h5>@Title</h5>
        }
        @foreach(var item in Mensajes)
        {
            <p class="mb-0">@(Mensajes.Count > 0 ? $"- {item}" : item)</p>
        }
    </div>
    
</div>

<div class="d-flex flex-row text-end justify-content-end mt-2">
    <button type="button" class="btn btn-light btn-sm" @onclick="@((args) => dialogService.Close(false))" style="width: 120px">Cerrar</button>

</div>

