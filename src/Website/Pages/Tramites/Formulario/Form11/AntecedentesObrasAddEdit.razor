@page "/Tramites/AntecedentesObras/{AccionFormAnterior}/{IdentificadorUnico}/{Accion}/{IdTramiteEspecialidad:int?}/{IdTramiteEspecialidadSeccion:int?}"
@page "/Tramites/AntecedentesObras/{AccionFormAnterior}/{IdentificadorUnico}/{Accion}/{IdTramiteAntecedente:int?}"

@using DataTransferObject;
@using Microsoft.AspNetCore.Authorization;
@using Website.Models.Formulario;
@attribute [Authorize]

@if (routeHistory.ProvieneBandejaTramites())
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "BandejaTramites","/BandejaTramites" },
                  { $"Trámite {tramite?.IdTramite}", $"/Tramites/Visualizar/{IdentificadorUnico}" },
                  { $"Formulario 11",$"/Tramites/Antecedentes/{AccionFormAnterior}/{IdentificadorUnico}"},
                  {$"{Accion} Antecedente de producción",""}
                  }) />
}
else
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "Iniciar Trámite","/Tramites/IniciarTramite" },
                  {"Consulta de trámites","/Tramites/ConsultarTramites"},
                  {$"Trámite {tramite?.IdTramite}",$"/Tramites/Visualizar/{IdentificadorUnico}"},
                  {$"Formulario 11",$"/Tramites/Antecedentes/{AccionFormAnterior}/{IdentificadorUnico}"},
                  {$"{Accion} Antecedente de producción",""}
                  }) />
}
<hr class="mt-2 mb-2" />

<h3>
    Tr&aacute;mite @tramite?.IdTramite - @Accion Obra de Antecedemtes de Producción - 
    <a href="/" @onclick=@(args => VolverAlVisor()) @onclick:preventDefault>Ir al Progreso del trámite</a>
</h3>


<EditForm Model="@Model" OnSubmit="OnClickGuardar">
    <Blazored.FluentValidation.FluentValidationValidator />

    <div class="mb-1 row mt-2">
        <label class="col-sm-2 col-form-label">Especialidad:</label>
        <div class="col-sm-10">
            <RadzenTextBox class="form-control"
                           @bind-value=@Model.DescripcionEspecialidad
                           Disabled="true" />
            
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Sección:</label>
        <div class="col-sm-10">
            <RadzenTextBox class="form-control"
                           @bind-value=@Model.DescripcionSeccion
                           Disabled="true" />

        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Obra:</label>
        <div class="col-sm-10 mt-1">
            <div class="d-flex flex-row justify-content-end">
                <CustomRadzenDropDown class="form-control"
                                      Name="ddlObra"
                                      AllowFiltering=true
                                      TextProperty="Descripcion"
                                      ValueProperty="Id"
                                      Data="@lstObrasPciaLP"
                                      FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                      Disabled="@(!tramite?.PermiteEditarEmpresa ?? false)"
                                      @bind-Value="@Model.IdObraPciaLp"
                                      Change="@ddlObraChanged"/>
                
                @if (tramite?.PermiteEditarEmpresa ?? false)
                {
                    <button type="button" class="btn btn-secondary ms-1" style="width:120px" @onclick=@AgregarObraClick>
                        <span class="d-flex flex-row justify-content-between align-items-center">
                            <span class="material-icons me-1" style="font-size:16px;cursor:pointer;">add</span>
                            <span>Agregar</span>
                        </span>
                    </button>
                }
            </div>
        </div>
        <div>
            <ValidationMessage For="() => Model.IdObraPciaLp" />
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Ubicación:</label>
        <div class="col-sm-10 mt-1">
            <RadzenTextBox class="form-control"
                            @bind-value=@Model.Ubicacion
                            MaxLength="300"
                           Disabled="@(!tramite.PermiteEditarEmpresa)" />
            <ValidationMessage For="() => Model.Ubicacion" />
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Comitente:</label>
        <div class="col-sm-10 mt-1">
            <RadzenTextBox class="form-control"
                            @bind-value=@Model.Comitente
                            MaxLength="20"
                            Disabled="@(!tramite.PermiteEditarEmpresa)"/>
            <ValidationMessage For="() => Model.Comitente" />
        </div>
    </div>


    <div class="mb-1 row">
        @if (tramite.IdGrupoTramite == StaticClass.Constants.GruposDeTramite.RegistroLicitadores)
        {
            <label class="col-sm-2 col-form-label">Per&iacute;odo Base:</label>
        }
        else
        {
            <label class="col-sm-2 col-form-label">Fecha de Contrato:</label>
        }
        <div class="col-sm-10">
            <div class="d-flex flex-row align-items-center">
                <CustomRadzenDropDown Style="width:80px"
                                        Name="ddlMeses"
                                        AllowFiltering=false
                                        TextProperty="Descripcion"
                                        ValueProperty="Id"
                                        Data="@lstMeses"
                                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        @bind-Value="@Model.MesBase"
                                      Disabled="@(!tramite.PermiteEditarEmpresa)" />

                <label class="p-1">/</label>

                <CustomRadzenNumeric TValue="int?" MaxIntegers="4" MaxDecimals="0" class="form-control"
                                        ShowUpDown="false" Style="width:80px"
                                        @bind-Value=@Model.AnioBase
                                     Disabled="@(!tramite.PermiteEditarEmpresa)" />
            </div>
            <div><ValidationMessage For="() => Model.MesBase" /></div>
            <div><ValidationMessage For="() => Model.AnioBase" /></div>
            <div><ValidationMessage For="() => Model.PeriodoBase" /></div>
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Per&iacute;odo Inicio:</label>
        <div class="col-sm-10">
            <div class="d-flex flex-row align-items-center">
                <CustomRadzenDropDown Style="width:80px"
                                      Name="ddlMeses"
                                      AllowFiltering=false
                                      TextProperty="Descripcion"
                                      ValueProperty="Id"
                                      Data="@lstMeses"
                                      FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                      @bind-Value="@Model.MesInicio" 
                                      Disabled="@(!tramite.PermiteEditarEmpresa)" />

                <label class="p-1">/</label>

                <CustomRadzenNumeric TValue="int?" MaxIntegers="4" MaxDecimals="0" class="form-control"
                                        ShowUpDown="false" Style="width:80px"
                                        @bind-Value=@Model.AnioInicio
                                     Disabled="@(!tramite.PermiteEditarEmpresa)" />
            </div>
            <div><ValidationMessage For="() => Model.MesInicio" /></div>
            <div><ValidationMessage For="() => Model.AnioInicio" /></div>
            <div><ValidationMessage For="() => Model.PeriodoInicio" /></div>
        </div>
    </div>


    <div class="mb-1 row">
        <div class="col-sm-2">
            @if(tramite.IdGrupoTramite == StaticClass.Constants.GruposDeTramite.RegistroLicitadores)
            {
                <label class="col-form-label pt-0 pb-0">Plazo:</label>
            }
            else
            {
                <label class="col-form-label pt-0 pb-0">Plazo de Contrato:</label>
            }
            <div class="small">(incluye ampliación de plazo)</div>
        </div>
        <div class="col-sm-10">
            <CustomRadzenNumeric TValue="int?" MaxIntegers="4" MaxDecimals="0" class="form-control"
                                    ShowUpDown="false" Style="width:80px" Format="N0"
                                    @bind-Value=@Model.Plazo
                                 Disabled="@(!tramite.PermiteEditarEmpresa)" />
            <label>d&Iacute;as</label>
            <div><ValidationMessage For="() => Model.Plazo" /></div>
        </div>
    </div>

    <div class="mb-1 row">
        <div class="col-sm-2">
            <label class="col-form-label pt-0 pb-0">Monto (sin MC) Contrato:</label>
            <div class="small">(incluye adicionales y deductivos)</div>
        </div>
        <div class="col-sm-10">
            <NumericBox TValue="decimal?" MaxIntegers="10" MaxDecimals="2" class="rz-textbox form-control"
                                 Style="width:300px" 
                                 @bind-Value=@Model.MontoContrato
                                 Disabled="@(!tramite.PermiteEditarEmpresa)" />
            <div><ValidationMessage For="() => Model.MontoContrato" /></div>
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Monto (sin MC) Ejecutado:</label>
        <div class="col-sm-10">
            <NumericBox TValue="decimal?" MaxIntegers="10" MaxDecimals="2" class="rz-textbox form-control"
                                 Style="width:300px" 
                                 @bind-Value=@Model.MontoEjecutado 
                                 Disabled="@(!tramite.PermiteEditarEmpresa)" />
            <div><ValidationMessage For="() => Model.MontoEjecutado" /></div>
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Monto (sin MC) a Ejecutar:</label>
        <div class="col-sm-10">

            <label class="rz-textbox form-control" style="width:300px">@(Model.MontoAejecutar.GetValueOrDefault().ToString("#,#.##"))</label>
            <div><ValidationMessage For="() => Model.MontoAejecutar" /></div>
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Representante técnico:</label>
        <div class="col-sm-10 mt-1">
            <RadzenTextBox class="form-control"
                           @bind-value=@Model.RepresentanteTecnico
                           MaxLength="20"
                           Disabled="@(!tramite.PermiteEditarEmpresa)" />
            <ValidationMessage For="() => Model.RepresentanteTecnico" />
        </div>
    </div>

    <div class="mb-1 row">
        <div class="col-sm-2">
            <label class="col-form-label">Archivo de Contrato:</label>
            <h4><span class="badge badge-outline-danger">Archivo Pdf</span></h4>
        </div>
        
        <div class="col-sm-10">
            <CustomFileUpload @ref="upload"
                              OnFileUploaded="HandleFileUploaded"
                              OnFileDeleted="HandleFileDeletionRequested"
                              OnError="HandleError"
                              OnProgress="OnProgress"
                              Files="@lstFiles"
                              ReadOnly="@(!tramite.PermiteEditarEmpresa)"
                              Accept="application/pdf">
            </CustomFileUpload>
            <ValidationMessage For="() => Model.IdFile" />
        </div>
    </div>

