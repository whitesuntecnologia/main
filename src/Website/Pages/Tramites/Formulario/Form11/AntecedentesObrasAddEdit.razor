    <div class="row mt-1">
        <div class="col-md-12">
            @if(tramite.PermiteEditarEmpresa)
            {
                if (!isBusyAceptar)
                {
                    <div class="d-flex flex-row justify-content-end">
                        <button type="button" class="btn btn-secondary" style="width:120px" @onclick=@CancelarClick>Cancelar</button>
                        <button type="submit" class="btn btn-success ms-1" style="width:120px">Guardar</button>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-row justify-content-end">
                        <Spinner1 Text="Guardando..."></Spinner1>
                    </div>
                
                }
            }
            else
            {
                <div class="d-flex flex-row justify-content-end">
                    <button type="button" class="btn btn-secondary" style="width:120px" @onclick=@CancelarClick>Cerrar</button>
                </div>
            }
        </div>
    </div>
</EditForm>



