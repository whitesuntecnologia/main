@page "/Tramites/Equipos/{Accion}/{IdentificadorUnico}"

@using DataTransferObject;
@using Microsoft.AspNetCore.Authorization;

@using StaticClass;
@using Website.Pages.Shared
@attribute [Authorize]

@if (routeHistory.ProvieneBandejaTramites())
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "BandejaTramites","/BandejaTramites" },
                  { $"Trámite {tramite?.IdTramite}", $"/Tramites/{Accion}/{IdentificadorUnico}" },
                  { $"Formulario 7",""}
                  }) />
}
else if (routeHistory.ProvieneConsultaTramites())
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "Consulta de Trámites","/Consultas/Tramites" },
                  { $"Trámite {tramite?.IdTramite}", $"/Tramites/{Accion}/{IdentificadorUnico}" },
                  { $"Formulario 7",""}
                  }) />
}
else
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "Iniciar Trámite","/Tramites/IniciarTramite" },
                  {"Consulta de trámites","/Tramites/ConsultarTramites"},
                  {$"Trámite {tramite?.IdTramite}",$"/Tramites/{Accion}/{IdentificadorUnico}"},
                  {$"Formulario 7",""}
                  }) />
}
<hr class="mt-2 mb-2" />

<h3>
    Tr&aacute;mite @tramite?.IdTramite - Equipos -
    <a href="/" @onclick=@(args => VolverAlVisor()) @onclick:preventDefault>Ir al Progreso del trámite</a>
</h3>


<EditForm  EditContext="@context" OnSubmit="OnClickAceptar">
    <Blazored.FluentValidation.FluentValidationValidator />


    @*Afectado*@
    <div class="card mt-3">
        <div class="card-header pt-1 pb-1 navbar-button">
            <div class="d-flex flex-row justify-content-between align-items-center">
                <div>
                    <h4 class="card-title mb-0">Equipos de la empresa - AFECTADO</h4>
                </div>
            </div>
        </div>

        <div class="card-body">

            <div class="mb-1 row">
                <label class="col-sm-2 col-form-label">Monto:</label>
                <div class="col-sm-10">
                    <NumericBox TValue="decimal?"
                    MaxIntegers="10"
                    MaxDecimals="2"
                    class="rz-textbox form-control"
                    Style="width:300px"
                    @bind-Value=@Model.Afectado.MontoRealizacion
                                Disabled="@(!PermiteEditar)" />

                    <div><ValidationMessage For="() => Model.Afectado.MontoRealizacion" /></div>
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-2">
                    <label class="col-form-label">Detalle del Equipo:</label>
                    <h4><span class="badge badge-outline-danger">Archivo Excel</span></h4>

                </div>
                <div class="col-sm-10">
                    <CustomFileUpload @ref="uploadDE"
                    OnFileUploaded="HandleFileUploadedDE"
                    OnFileDeleted="HandleFileDeletionRequestedDE"
                    OnError="HandleErrorDE"
                    OnProgress="OnProgressDE"
                    Files="@lstFilesDE"
                                      ReadOnly="@(!PermiteEditar)"
                    Accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet">
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.Afectado.IdFileDetalleEquipo" />
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-2">
                    <label class="col-form-label">Certificado Contable:</label>
                    <h4><span class="badge badge-outline-danger">Archivo Pdf</span></h4>
                </div>

                <div class="col-sm-10">
                    <CustomFileUpload @ref="uploadCC"
                    OnFileUploaded="HandleFileUploadedCC"
                    OnFileDeleted="HandleFileDeletionRequestedCC"
                    OnError="HandleErrorCC"
                    OnProgress="OnProgressCC"
                    Files="@lstFilesCC"
                                      ReadOnly="@(!PermiteEditar)"
                    Accept="application/pdf,">
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.Afectado.IdFileCertificadoContable" />
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-2">
                    <label class="col-form-label">Documentación Equipo:</label>
                    <h4><span class="badge badge-outline-danger">Archivo Pdf</span></h4>
                </div>

                <div class="col-sm-10">
                    <CustomFileUpload @ref="uploadDoc"
                    OnFileUploaded="HandleFileUploadedDoc"
                    OnFileDeleted="HandleFileDeletionRequestedDoc"
                    OnError="HandleErrorDoc"
                    OnProgress="OnProgressDoc"
                    Files="@lstFilesDoc"
                                      ReadOnly="@(!PermiteEditar)"
                    Accept="application/pdf,">
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.Afectado.IdFileDocumentacionEquipo" />
                </div>
            </div>

            @if (lstPerfiles.Exists(x => x.IdPerfil == Constants.Perfiles.Administrador) ||
               lstPerfiles.Exists(x => x.IdPerfil == Constants.Perfiles.Evaluador))
            {
                <div class="mb-1 row">
                    <label class="col-sm-2 col-form-label">Nuevo Monto:</label>
                    <div class="col-sm-10">
                        <NumericBox TValue="decimal?"
                        MaxIntegers="10"
                        MaxDecimals="2"
                        class="rz-textbox form-control"
                        Style="width:300px"
                        @bind-Value=@Model.Afectado.MontoRealizacionEvaluador
                        Disabled="@(!EvaluandoTramite)" />

                        <div><ValidationMessage For="() => Model.Afectado.MontoRealizacionEvaluador" /></div>
                    </div>
                </div>
            }
        </div>
    </div>


    @*No Afectado*@
    <div class="card mt-3">
        <div class="card-header pt-1 pb-1 navbar-button">
            <div class="d-flex flex-row justify-content-between align-items-center">
                <div>
                    <h4 class="card-title mb-0">Equipos de la empresa - NO AFECTADO</h4>
                </div>
            </div>
        </div>

        <div class="card-body">

            <div class="mb-1 row">
                <label class="col-sm-2 col-form-label">Monto:</label>
                <div class="col-sm-10">
                    <NumericBox TValue="decimal?"
                    MaxIntegers="10"
                    MaxDecimals="2"
                    class="rz-textbox form-control"
                    Style="width:300px"
                    @bind-Value=@Model.NoAfectado.MontoRealizacion
                                Disabled="@(!PermiteEditar)" />

                    <div><ValidationMessage For="() => Model.NoAfectado.MontoRealizacion" /></div>
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-2">
                    <label class="col-form-label">Detalle del Equipo:</label>
                    <h4><span class="badge badge-outline-danger">Archivo Excel</span></h4>

                </div>
                <div class="col-sm-10">
                    <CustomFileUpload @ref="uploadDE"
                    OnFileUploaded="HandleFileUploadedDE2"
                    OnFileDeleted="HandleFileDeletionRequestedDE2"
                    OnError="HandleErrorDE2"
                    OnProgress="OnProgressDE2"
                    Files="@lstFilesDE2"
                                      ReadOnly="@(!PermiteEditar)"
                    Accept="application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet">
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.NoAfectado.IdFileDetalleEquipo" />
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-2">
                    <label class="col-form-label">Certificado Contable:</label>
                    <h4><span class="badge badge-outline-danger">Archivo Pdf</span></h4>
                </div>

                <div class="col-sm-10">
                    <CustomFileUpload @ref="uploadCC"
                    OnFileUploaded="HandleFileUploadedCC2"
                    OnFileDeleted="HandleFileDeletionRequestedCC2"
                    OnError="HandleErrorCC2"
                    OnProgress="OnProgressCC2"
                    Files="@lstFilesCC2"
                                      ReadOnly="@(!PermiteEditar)"
                    Accept="application/pdf,">
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.NoAfectado.IdFileCertificadoContable" />
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-2">
                    <label class="col-form-label">Documentación Equipo:</label>
                    <h4><span class="badge badge-outline-danger">Archivo Pdf</span></h4>
                </div>

                <div class="col-sm-10">
                    <CustomFileUpload @ref="uploadDoc2"
                    OnFileUploaded="HandleFileUploadedDoc2"
                    OnFileDeleted="HandleFileDeletionRequestedDoc2"
                    OnError="HandleErrorDoc2"
                    OnProgress="OnProgressDoc2"
                    Files="@lstFilesDoc2"
                                      ReadOnly="@(!PermiteEditar)"
                    Accept="application/pdf,">
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.NoAfectado.IdFileDocumentacionEquipo" />
                </div>
            </div>

            @if (lstPerfiles.Exists(x => x.IdPerfil == Constants.Perfiles.Administrador) ||
                   lstPerfiles.Exists(x => x.IdPerfil == Constants.Perfiles.Evaluador))
            {
                <div class="mb-1 row">
                    <label class="col-sm-2 col-form-label">Nuevo Monto:</label>
                    <div class="col-sm-10">
                        <NumericBox TValue="decimal?"
                        MaxIntegers="10"
                        MaxDecimals="2"
                        class="rz-textbox form-control"
                        Style="width:300px"
                        @bind-Value=@Model.NoAfectado.MontoRealizacionEvaluador
                        Disabled="@(!EvaluandoTramite)" />

                        <div><ValidationMessage For="() => Model.NoAfectado.MontoRealizacionEvaluador" /></div>
                    </div>
                </div>
            }

        </div>
    </div>

    <div class="d-flex flex-row text-end justify-content-end">
        @if (PermiteEditar)
        {
            if (!isBusyAceptar)
            {
                <button type="submit" class="btn btn-success" style="width: 120px">Guardar</button>

            }
            else
            {
                <Spinner1 Text="Guardando..."></Spinner1>
            }
        }
    </div>


</EditForm>

@if (tramite?.PermiteEditarFormulario(StaticClass.Constants.Formularios.Equipos) ?? false)
{
    <FormEvaluacion IdentificadorUnico="@IdentificadorUnico"
                NroFormulario="7"
                OnGuardarClick="GuardarEvaluacionClick"
                OnCancelarClick="CancelarEvaluacionClick"
                Visible="@EvaluandoTramite">
    </FormEvaluacion>
}