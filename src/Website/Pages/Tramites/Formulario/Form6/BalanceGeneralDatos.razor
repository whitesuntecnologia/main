@*Totales*@
<div class="card mt-1">
    <div class="card-header pt-1 pb-1 navbar-button">
        <div class="d-flex flex-row justify-content-between align-items-center">
            <div>
                <h4 class="card-title mb-0">Estados Contables (Totales)</h4>
            </div>
        </div>
    </div>

    <div class="card mt-1">
        <div class="card-body">
            <div class="d-flex flex-row text-center">
                    <div class="col-1 text-center">
                    <div>Fecha</div>
                </div>
                <div class="col-1">
                    <div>Activo total</div>
                </div>
                <div class="col-2">
                    <div>Activo Corriente Total</div>
                </div>
                <div class="col-2">
                    <div>Activo No Corriente Total</div>
                </div>
                <div class="col-2">
                    <div>Pasivo Total</div>
                </div>
                <div class="col-2">
                    <div>Pasivo Corriente Total</div>
                </div>
                <div class="col-2">
                    <div>Pasivo No Corriente Total</div>
                </div>
            </div>
            <div class="d-flex flex-row text-center">
                    <div class="col-1 text-center">
                    @Model.FechaBalance?.ToString("dd/MM/yyyy")
                </div>
                <div class="col-1">
                    <div>@(Model.ActivoTotal.ToString("C"))</div>
                </div>
                <div class="col-2">
                        <div>@(Model.ActivoCorrienteTotal.ToString("C"))</div>
                </div>
                <div class="col-2">
                    <div>@(Model.ActivoNoCorrienteTotal.ToString("C"))</div>
                </div>
                <div class="col-2">
                    <div>@(Model.PasivoTotal.ToString("C"))</div>
                </div>
                <div class="col-2">
                        <div>@(Model.PasivoCorrienteTotal.ToString("C"))</div>
                </div>
                <div class="col-2">
                        <div>@(Model.PasivoNoCorrienteTotal.ToString("C"))</div>
                </div>
            </div>
        </div>
    </div>
</div>
@*Estados Contables*@
<div class="card mt-1">
    <div class="card-header pt-1 pb-1 navbar-button">
        <div class="d-flex flex-row justify-content-between align-items-center">
            <div>
                <h4 class="card-title mb-0">Estados Contables / Información según Normativa Vigente</h4>
            </div>
        </div>
    </div>

    <div class="card-body">

        <div class="alert alert-warning">
                Por favor, adjunte el archivo de los Estados Contables, con Informe de Auditoría emitido por 
                Contador Público Nacional, legalizado por el Consejo Profesional de Ciencias Económicas 
                respectivo. Acta aprobatoria de documentación contable, memoria y distribución de utilidades 
                en formato PDF. En el caso que no posean esta información, se puede presentar una Manifestación 
                de Bienes con certificación de Contador Público legalizada por el Consejo Profesional de Ciencias 
                Económicas respectivo de acuerdo al modelo sugerido por este Registro también en formato PDF.
        </div>

        <CustomFileUpload @ref="upload"
                            OnFileUploaded="HandleFileUploaded"
                            OnFileDeleted="HandleFileDeletionRequested"
                            OnError="HandleError"
                            OnProgress="OnProgress"
                            Files="@lstFiles"
                            ReadOnly="@ReadOnly"
                            DisableAddFile="@ReadOnly"
                            Accept="application/pdf" >
        </CustomFileUpload>
        <ValidationMessage For="() => Model.IdFile" />

    </div>
</div>


    
