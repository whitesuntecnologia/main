
<div class="card mt-3">
    <div class="card-header pt-1 pb-1 navbar-button">
        <div class="d-flex flex-row justify-content-between align-items-center">
            <div>
                <h4 class="card-title mb-0">DATOS INICIALES</h4>
            </div>
        </div>
    </div>

    <div class="card-body">

        <div class="d-flex align-items-center">
            <label class="col-sm-4 text-end pe-2">A&ntilde;o:</label>
            <div class="col-sm-8">
                <div class="d-flex flex-row align-items-center">
                    <CustomRadzenNumeric TValue="int?"
                                            MaxIntegers="4"
                                            MaxDecimals="0"
                                            ShowUpDown="false"
                                            @bind-Value="@Model.Anio"
                                            Disabled="true"
                                            class="form-control width-100">
                    </CustomRadzenNumeric>
                    @if (ReadOnly && ButtonEditVisible)
                    {
                        <button type="button" class="btn btn-violet" @onclick=@EditarBalanceClick>
                            <span class="d-flex flex-row justify-content-between align-items-center">
                                <span class="material-icons me-1" style="font-size:16px;cursor:pointer;">edit</span>
                                <span>Editar Balance</span>
                            </span>
                        </button>
                    }
                </div>
                <div>
                    <ValidationMessage For="() => Model.Anio" />
                </div>
            </div>
        </div>

        <div class="d-flex align-items-center mt-1">
            <label class="col-sm-4 text-end pe-2">Fecha Balance:</label>
            <div class="col-sm-8">
                <RadzenDatePicker TValue="DateTime?"
                                  DateFormat="d" 
                                    Disabled="@ReadOnly"
                                    @bind-Value=@Model.FechaBalance
                                    Max="DateTime.Today.AddDays(1)">
                </RadzenDatePicker>
                    
                <div>
                    <ValidationMessage For="() => Model.FechaBalance" />
                </div>
            </div>
        </div>

    </div>
</div>

@*Obras oficiales*@
