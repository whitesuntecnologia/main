@if (Model.IdTipoTramite == StaticClass.Constants.TiposDeTramite.Reli_Licitar)
    {
        <div class="row mt-1">
            <div class="col-12 d-flex">
                <label class="col-form-label ps-2 pe-2">Monto de la Obra a Licitar:</label>
                <NumericBox TValue="decimal"
                class="form-control width-150 text-end me-2"
                MaxIntegers="10"
                MaxDecimals="2"
                Disabled="true"
                @bind-Value=@Model.MontoObra>
                </NumericBox>
                @if (Model.lstConstanciaCapacidad.Sum(o => o.CapacidadContratacion) < Model.MontoObra)
                {
                    <div class="alert alert-warning inline-block m-0 p-1">
                        El Monto de la Obra es superior a la Capacidad de Contratación
                    </div>
                }
            </div>
        </div>

        <div class="row mt-1">
            <div class="col-12 d-flex">
                <label class="col-form-label ps-2 pe-2">Capacidad técnica requerida: @Model.MontoObra.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</label>
            </div>
        </div>


        <div class="row mt-1">
            <div class="col-12 d-flex">
                <label class="col-form-label ps-2 pe-2">Capacidad de Contratación requerida: @Model.CapacidadContratacionAnualRequerida.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</label>
            </div>
        </div>

        <div class="row mt-1">
            <div class="col-12 d-flex">
                <label class="col-form-label ps-2 pe-2">Fecha de Vencimiento de la Constancia Anterior: 
                    @(
                                Model.FechaVencimientoConstanciaAnterior.HasValue
                                                             ? Model.FechaVencimientoConstanciaAnterior.Value.ToString("dd/MM/yyyy")
                                                             : string.Empty
                                )
                            </label>

                @if (Model.FechaVencimientoConstanciaAnterior.HasValue && Model.FechaVencimientoConstanciaAnterior.Value < DateTime.Now.Date)
                {
                    <div class="alert alert-warning m-0 p-1">
                        La Constancia de Inscripción se encuentra vencida.
                    </div>
                }
            </div>
        </div>
    }
}
