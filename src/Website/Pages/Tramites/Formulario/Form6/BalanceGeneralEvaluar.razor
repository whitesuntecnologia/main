                <RadzenDataGridColumn TItem="BalanceGeneral_ConstanciaCapacidadItem_Evaluar_Model" Property="CapacidadContratacionUVI" Title="Actualizada UVI" FormatString="{0:C2}" Filterable="false" TextAlign="TextAlign.End" Width="250px" />
                <RadzenDataGridColumn TItem="BalanceGeneral_ConstanciaCapacidadItem_Evaluar_Model" Property="EjecucaionAnual" Title="Ejecución Anual" FormatString="{0:C2}" Filterable="false" TextAlign="TextAlign.End" Width="250px" />
                <RadzenDataGridColumn TItem="BalanceGeneral_ConstanciaCapacidadItem_Evaluar_Model" Property="EjecucaionAnualUVI" Title="Actualizada UVI" FormatString="{0:C2}" Filterable="false" TextAlign="TextAlign.End" Width="250px" />
            </Columns>
            <EmptyTemplate>
                <div class="d-flex flex-row align-items-center">
                    <span class="material-icons" style="font-size:64px; color:lightgray">
                        block
                    </span>
                    <strong class="ms-1">@StaticClass.Constants.DatagridNoRecords</strong>
