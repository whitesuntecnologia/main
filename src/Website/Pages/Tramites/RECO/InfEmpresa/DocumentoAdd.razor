@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize]
<hr class="mt-1 mb-0" />

<EditForm Model="@Model" OnSubmit="OnClickAceptar">
    <DataAnnotationsValidator />
    <Blazored.FluentValidation.FluentValidationValidator />

    <RadzenLayout  Style="height: auto">
        <RadzenBody class="mbottom30">
            <div class="mb-1 row">
                <div class="col-sm-12">
                    <label class="col-form-label">Tipo de Documento:</label>

                    <CustomRadzenDropDown class="form-control"
                                          Name="ddlTipoDoc"
                                          AllowFiltering=true
                                          TextProperty="Descripcion"
                                          ValueProperty="Id"
                                          Data="@lstTiposDeDocumentos"
                                          FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                          @bind-Value="@Model.IdTipoDocumento"
                                          Disabled="true"
                                           />
                    <ValidationMessage For="() => Model.IdTipoDocumento" />
                </div>
            </div>

            <div class="mb-1 row">
                <div class="col-sm-12">
                    <CustomFileUpload @ref="upload"
                                      OnFileUploaded="HandleFileUploaded"
                                      OnFileDeleted="HandleFileDeletionRequested"
                                      OnError="HandleError"
                                      OnProgress="OnProgress"
                                      Files="@lstFiles"
                                      ReadOnly="false"
                                      Accept="application/pdf" >
                    </CustomFileUpload>
                    <ValidationMessage For="() => Model.IdFile" />
                </div>
            </div>

        

        </RadzenBody>
        <RadzenFooter class="mt-3">
            <div class="d-flex flex-row text-end justify-content-end">
               
                @if (!isBusyFileUpload && !isBusyAceptar)
                {
                    <button type="submit" class="btn btn-violet me-1" style="width: 120px">Aceptar</button>
                    <button type="button" class="btn btn-light" @onclick="@((args) => dialogService.Close(false))" style="width: 120px">Cancelar</button>
                }
                @if(isBusyAceptar)
                {
                    <div class="spinner-border text-pink" role="status"></div>
                }
                
            </div>
           
        </RadzenFooter>
        
    </RadzenLayout>
</EditForm>



