@page "/Tramites/RECO/Especialidades/{Accion}/{IdentificadorUnico}"

@using DataTransferObject;
@using Microsoft.AspNetCore.Authorization;
@using Website.Models.Formulario
@using Website.Pages.Shared;
@attribute [Authorize]

@if (routeHistory.ProvieneBandejaTramites())
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                                    { "BandejaTramites","/BandejaTramites" },
                                    { $"Trámite {tramite?.IdTramite}", $"/Tramites/{Accion}/{IdentificadorUnico}" },
                                    { $"Formulario 1",""}
                                    }) />
}
else if (routeHistory.ProvieneConsultaTramites())
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                                    { "Consulta de Trámites","/Consultas/Tramites" },
                                    { $"Trámite {tramite?.IdTramite}", $"/Tramites/{Accion}/{IdentificadorUnico}" },
                                    { $"Formulario 1",""}
                                    }) />
}
else
{
    <CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                                    { "Iniciar Trámite","/Tramites/IniciarTramite"},
                                    { "Consulta de trámites","/Tramites/ConsultarTramites"},
                                    { $"Trámite {tramite?.IdTramite}",$"/Tramites/{Accion}/{IdentificadorUnico}"},
                                    { $"Formulario 1",""}
                                    }) />
}

<hr class="mt-2 mb-2" />


<h3>
    Tr&aacute;mite @tramite?.IdTramite - Especialidades -
    <a href="/" @onclick=@(args => VolverAlVisor()) @onclick:preventDefault>Ir al Progreso del trámite</a>
</h3>

<div class="card mt-3">
    <div class="card-header pt-2 pb-2 navbar-button">
        <div class="d-flex flex-row justify-content-between align-items-center">
            <div>
                <h4 class="card-title mb-0">Lista de Especialidades</h4>
            </div>
        </div>
    </div>
    <div class="card-body">

        <h4>RAMA C - Obras Complementarias</h4>

        <div class="row mt-1">
            <div class="col-12">
                <div class="p-1 rz-background-color-base-100 rz-border-color-base-300 w-100" style="border:1px solid;">
                    Cantidad de registros: @lstEspecialidadesSecciones.Count
                </div>

                <RadzenDataGrid @ref="grdEspecialidadesSecciones"
                                Count="@lstEspecialidadesSecciones.Count"
                                Data="@lstEspecialidadesSecciones"
                                AllowSorting="true"
                                AllowPaging="false"
                                AllowRowSelectOnRowClick="false"
                                SelectionMode="DataGridSelectionMode.Multiple" 
                                @bind-Value="@lstEspecialidadesSeccionesSelecteds"
                                AllowColumnResize="true"
                                TItem="EspecialidadSeccionDTO">

                    <Columns>

                        <RadzenDataGridColumn TItem="EspecialidadSeccionDTO" Property="DescripcionSeccion" Title="Sección" />
                        <RadzenDataGridColumn AllowCheckBoxListVirtualization="true" TItem="EspecialidadSeccionDTO" Property="Seleccionada" Title="Seleccionada">
                            <Template Context="data">
                                <RadzenCheckBox TriState="false" Value="@(lstEspecialidadesSeccionesSelecteds != null && lstEspecialidadesSeccionesSelecteds.Contains(data))"
                                                TValue="bool" Change=@(args => {  grdEspecialidadesSecciones.SelectRow(data);  }) />
                                
                            </Template>
                        </RadzenDataGridColumn>

                    </Columns>
                    <EmptyTemplate>
                        <div class="d-flex flex-row align-items-center">
                            <span class="material-icons" style="font-size:64px; color:lightgray">
                                block
                            </span>
                            <strong class="ms-1">@StaticClass.Constants.DatagridNoRecords</strong>
                        </div>
                    </EmptyTemplate>
                </RadzenDataGrid>
            </div>

        </div>

    </div>
</div>
<div class="row mt-2">
    <div class="col-md-12 text-end">
        @if (tramite != null && tramite!.PermiteEditarEmpresa)
        {
            if (!IsBusyGuardar)
            {
                <button type="button" class="btn btn-success" style="width:120px" @onclick="@OnClickAceptar">Guardar</button>
            }
            else
            {
                <div class="spinner-border text-pink" role="status"></div>
            }
        }
    </div>
</div>


@if (tramite?.PermiteEditarFormulario(StaticClass.Constants.Formularios.Especialidades) ?? false)
{
    <FormEvaluacion IdentificadorUnico="@IdentificadorUnico"
                    NroFormulario="1"
                    OnGuardarClick="GuardarEvaluacionClick"
                    OnCancelarClick="CancelarEvaluacionClick"
                    Visible="@EvaluandoTramite">
    </FormEvaluacion>
}