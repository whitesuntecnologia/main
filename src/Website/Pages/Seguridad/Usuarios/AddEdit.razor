@page "/Seguridad/Usuarios/Editar/{userid}"
@page "/Seguridad/Usuarios/Agregar"
@using DataTransferObject;
@using Microsoft.AspNetCore.Authorization;

@attribute [Authorize(Roles = "UsuariosEditar")]

<CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "Seguridad","/14" },
                  {$"Usuarios","/Seguridad/Usuarios"},
                  {$"{Accion} Usuario",""}
                  }) />
<hr class="mt-2 mb-2" />


<h3>
    @Accion Usuario
</h3>

<EditForm Model="@Model" OnSubmit="OnClickAceptar">
    <Blazored.FluentValidation.FluentValidationValidator />
    
    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label mt-1">Perfiles:</label>
        <div class="col-sm-10">
            <RadzenCheckBoxList Data="@lstPerfiles"
                                @bind-Value=@Model.CheckedValues
                                TValue="int"
                                TextProperty="Descripcion"
                                ValueProperty="Id"
                                class="mb-1" />

            <ValidationMessage For="() => Model.CheckedValues" />
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Nombre de Usuario / CUIT:</label>
        <div class="col-sm-10 mt-1">
            <RadzenTextBox class="form-control"
                            @bind-value=@Model.UserName
                            MaxLength="50" />
            <ValidationMessage For="() => Model.UserName" />
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Nombre y Apellido:</label>
        <div class="col-sm-10 mt-1">
            <RadzenTextBox class="form-control"
            @bind-value=@Model.NombreyApellido
            MaxLength="50" />
            <ValidationMessage For="() => Model.NombreyApellido" />
        </div>
    </div>

    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Email:</label>
        <div class="col-sm-10 mt-1">
            <RadzenTextBox class="form-control"
                            @bind-value=@Model.Email
                            MaxLength="200" />
            <ValidationMessage For="() => Model.Email" />
        </div>
    </div>
   
    <div class="mb-1 row">
        <label class="col-sm-2 col-form-label">Estado:</label>
        <div class="col-sm-10">
                <CustomRadzenDropDown class="form-control"
                                    Name="ddlEstado"
                                    AllowFiltering=true
                                    TextProperty="Descripcion"
                                    ValueProperty="Id"
                                    Data="@lstEstados"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    @bind-Value="@Model.Estado" />

            <ValidationMessage For="() => Model.Estado" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-md-12">
            @if (!isBusyAceptar)
            {
                <div class="d-flex flex-row justify-content-end">
                    <button type="button" class="btn btn-secondary" style="width:120px" @onclick=@CancelarClick>Cancelar</button>
                    <button type="submit" class="btn btn-success ms-1" style="width:120px">Guardar</button>
                </div>
            }
            else
            {
                <Spinner1 Text="Guardando..." />
            }
        </div>
    </div>

</EditForm>

