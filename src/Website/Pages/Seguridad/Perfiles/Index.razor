@page "/Seguridad/Perfiles"

@using DataTransferObject;
@using Microsoft.AspNetCore.Authorization;
@attribute [Authorize]

<CustomBreadCrumb Path=@(new Dictionary<string, string>(){
                  { "Seguridad","/14" },
                  {$"Perfiles",""}
                  }) />
<hr class="mt-2 mb-2" />

<h3>
    Administración de permisos de los perfiles 
</h3>

<div class="card mt-3">
    <div class="card-header pt-1 pb-1 navbar-button">
        <div class="d-flex flex-row justify-content-between align-items-center">
            <div>
                <h4 class="card-title mb-0">Listado de Perfiles</h4>
            </div>
        </div>
    </div>

    <div class="card-body">

        <div class="card-body p-0 mb-1">
            <div class="p-1 rz-background-color-base-100 rz-border-color-base-300 w-100" style="border:1px solid;">
                Cantidad de registros: @lstPerfiles.Count()
            </div>
            <div class="row">
                <div class="col-12">
                    <RadzenDataGrid @ref="grdPerfiles"
                                    Count="@lstPerfiles.Count"
                                    Data="@lstPerfiles"
                                    AllowSorting="true"
                                    AllowPaging="false"
                                    AllowColumnResize="true"
                                    TItem="PerfilDTO">
                        <Columns>

                            <RadzenDataGridColumn TItem="PerfilDTO" Property="IdPerfil" Title="Id" Filterable="false" />
                            <RadzenDataGridColumn TItem="PerfilDTO" Property="Nombre" Title="Nombre" Filterable="false" />
                            <RadzenDataGridColumn TItem="PerfilDTO" Property="IdTramiteObraEjec" Title="Acciones" Sortable="false" Filterable="false" CssClass="text-center" Width="130px">
                                <Template Context="data">
                                    <div class="ps-1">
                                        <RadzenButton Click="@(e => EditarClick(data))"
                                                      data-toggle="tooltip"
                                                      data-placement="top"
                                                      title="Editar"
                                                      Icon="edit"
                                                      ButtonType="ButtonType.Button"
                                                      ButtonStyle="ButtonStyle.Light">

                                        </RadzenButton>

                                    </div>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                        <EmptyTemplate>
                            <div class="d-flex flex-row align-items-center">
                                <span class="material-icons" style="font-size:64px; color:lightgray">
                                    block
                                </span>
                                <strong class="ms-1">@StaticClass.Constants.DatagridNoRecords</strong>
                            </div>
                        </EmptyTemplate>
                    </RadzenDataGrid>
                </div>
            </div>

        </div>
    </div>
</div>


